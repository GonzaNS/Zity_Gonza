# Supabase — cliente público (frontend)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Dominio público donde corre la app desplegada. Se inyecta en los enlaces
# de verificación/reset que Supabase Auth incluye en los correos.
# En local déjalo vacío y se usa window.location.origin (http://localhost:5173).
VITE_SITE_URL=https://zity.site

# Solo servidor (edge functions, seed script, CI) — NUNCA exponer al frontend
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — email transaccional (Edge Function notificar-cambio-estado).
# Si RESEND_API_KEY está ausente, la función opera en modo dry-run: loguea el
# email en vez de enviarlo (modo por defecto en local y CI).
RESEND_API_KEY=your-resend-api-key

# Sprint 6 — remitente del email de cambio de estado. DEBE pertenecer a un
# dominio verificado en Resend. Default del código: "Zity <no-reply@zity.site>".
# Se configura como Secret en Supabase (Edge Functions) para envíos reales.
RESEND_FROM_ADDRESS="Zity <no-reply@zity.site>"
